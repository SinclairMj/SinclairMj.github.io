---
interface Props {
	title: string;
}

const { title } = Astro.props;
import NavButton from '../components/NavButton.astro';
import GlassButton from '../components/GlassButton.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Moltin Site">
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="img/favicon/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>MoltinSite</title>
	</head>
	<body>
		<div class="navigation">
			<div class="home-button">
				<GlassButton />
			</div>
			<nav class="nav-buttons">
				<NavButton href="/about" text="About" />
				<NavButton href="/contact" text="Contact" />
				<NavButton href="/blog" text="Blog" />
			</nav>
		</div>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(45deg, rgb(var(--accent)), rgb(var(--accent-light)) 30%, white 60%);
	}
	
	html {
		font-family: system-ui, sans-serif;
		background: linear-gradient(180deg, #FFE5B4 0%, #FFB4B4 100%);
		min-height: 100vh;
	}

	body {
		margin: 0;
		min-height: 100vh;
	}

	code {
		font-family: Menlo, Monaco, Lucida Console, Liberation Mono, DejaVu Sans Mono,
			Bitstream Vera Sans Mono, Courier New, monospace;
	}

	.navigation {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		padding: 1rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		z-index: 1000;
	}

	.home-button {
		margin-left: 1rem;
	}

	.nav-buttons {
		display: flex;
		gap: 0.5rem;
		margin-right: 1rem;
	}
</style>