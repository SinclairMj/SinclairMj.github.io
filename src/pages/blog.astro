---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="Blog Access">
  <main class="blog-access">
    <div class="access-container">
      <h1 class="page-title">Blog Access</h1>
      <p class="subtitle">Enter password to access the blog</p>
      
      <form class="password-form" id="passwordForm">
        <div class="input-group">
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="Enter password"
            required
            class="password-input"
          />
          <button type="submit" class="submit-button">Access Blog</button>
        </div>
        <div id="errorMessage" class="error-message"></div>
      </form>
    </div>
  </main>
</BlogLayout>

<style>
  .blog-access {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 2rem;
  }

  .access-container {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    padding: 3rem;
    text-align: center;
    max-width: 500px;
    width: 100%;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: bold;
    background: linear-gradient(to right, #ff6b6b, #4ecdc4, #ff6b6b);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    margin: 0 0 1rem 0;
  }

  .subtitle {
    font-size: 1.1rem;
    color: rgba(0, 0, 0, 0.7);
    margin: 0 0 2rem 0;
  }

  .password-form {
    width: 100%;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .password-input {
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(5px);
    font-size: 1rem;
    color: #333;
    outline: none;
    transition: all 0.3s ease;
  }

  .password-input:focus {
    border-color: rgba(255, 107, 107, 0.5);
    background: rgba(255, 255, 255, 0.2);
  }

  .password-input::placeholder {
    color: rgba(0, 0, 0, 0.5);
  }

  .submit-button {
    padding: 1rem 2rem;
    background: linear-gradient(45deg, #ff6b6b, #4ecdc4);
    border: none;
    border-radius: 10px;
    color: white;
    font-size: 1rem;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .submit-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }

  .submit-button:active {
    transform: translateY(0);
  }

  .error-message {
    color: #ff6b6b;
    font-size: 0.9rem;
    margin-top: 1rem;
    min-height: 1.2rem;
  }

  @media (max-width: 768px) {
    .access-container {
      padding: 2rem;
      margin: 1rem;
    }

    .page-title {
      font-size: 2rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('passwordForm') as HTMLFormElement;
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const errorMessage = document.getElementById('errorMessage') as HTMLElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const password = passwordInput.value;
      
      // 简单的密码验证（实际应用中应该使用更安全的方式）
      if (password === 'moltin2025') {
        // 存储认证状态到sessionStorage
        sessionStorage.setItem('blogAuthenticated', 'true');
        // 重定向到博客列表页面
        window.location.href = '/blog/list';
      } else {
        errorMessage.textContent = 'Incorrect password. Please try again.';
        passwordInput.value = '';
        passwordInput.focus();
      }
    });

    // 检查是否已经认证
    if (sessionStorage.getItem('blogAuthenticated') === 'true') {
      window.location.href = '/blog/list';
    }
  });
</script>
