---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getAllPosts, getAllCategories, getAllTags } from '../../utils/blog';
import type { BlogPostMeta } from '../../utils/blog';

// 在构建时获取文章数据
let posts: BlogPostMeta[] = [];
let categories: string[] = [];
let tags: string[] = [];

// 检查是否在Cloudflare环境中
// 在Cloudflare环境中，process.cwd() 会抛出错误
let isCloudflareEnv = false;
try {
  process.cwd();
  isCloudflareEnv = false;
} catch (error) {
  isCloudflareEnv = true;
}

if (isCloudflareEnv) {
  console.log('Detected Cloudflare environment, redirecting to error page');
  return Astro.redirect('/blog/error');
}

try {
  posts = getAllPosts();
  categories = getAllCategories();
  tags = getAllTags();
  
  // 如果没有文章数据，也重定向到错误页面
  if (posts.length === 0) {
    console.log('No blog posts found, redirecting to error page');
    return Astro.redirect('/blog/error');
  }
} catch (error) {
  console.error('Error loading blog posts:', error);
  // 如果无法加载文章，重定向到错误页面
  return Astro.redirect('/blog/error');
}
---

<BlogLayout title="Blog List">
  <main class="blog-list">
    <div class="blog-container">
      <header class="blog-header">
        <h1 class="page-title">My Blog</h1>
        <p class="subtitle">Personal articles and thoughts</p>
      </header>

      <div class="blog-controls">
        <div class="search-section">
          <input 
            type="text" 
            id="searchInput" 
            placeholder="Search articles..." 
            class="search-input"
          />
        </div>

        <div class="filter-section">
          <div class="filter-group">
            <label for="categoryFilter">Category:</label>
            <select id="categoryFilter" class="filter-select">
              <option value="">All Categories</option>
              {categories.map(category => (
                <option value={category}>{category}</option>
              ))}
            </select>
          </div>

          <div class="filter-group">
            <label for="tagFilter">Tag:</label>
            <select id="tagFilter" class="filter-select">
              <option value="">All Tags</option>
              {tags.map(tag => (
                <option value={tag}>{tag}</option>
              ))}
            </select>
          </div>
        </div>
      </div>

      <div class="posts-grid" id="postsGrid">
        {posts.map(post => (
          <article class="post-card" data-categories={post.categories.join(',')} data-tags={post.tags.join(',')}>
            <div class="post-header">
              <h2 class="post-title">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <div class="post-meta">
                <span class="author">By {post.author}</span>
                <span class="date">{new Date(post.date).toLocaleDateString()}</span>
              </div>
            </div>
            
            <div class="post-content">
              <p class="post-description">{post.description}</p>
              
              <div class="post-categories">
                {post.categories.map(category => (
                  <span class="category-tag">{category}</span>
                ))}
              </div>
              
              <div class="post-tags">
                {post.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

      <div id="noResults" class="no-results" style="display: none;">
        <p>No articles found matching your criteria.</p>
      </div>
    </div>
  </main>
</BlogLayout>

<style>
  .blog-list {
    min-height: 100vh;
    padding: 2rem;
    padding-top: 6rem;
  }

  .blog-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 3rem;
    font-weight: bold;
    background: linear-gradient(to right, #ff6b6b, #4ecdc4, #ff6b6b);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    margin: 0 0 1rem 0;
  }

  .subtitle {
    font-size: 1.2rem;
    color: rgba(0, 0, 0, 0.7);
    margin: 0;
  }

  .blog-controls {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 15px;
    padding: 2rem;
    margin-bottom: 3rem;
  }

  .search-section {
    margin-bottom: 1.5rem;
  }

  .search-input {
    width: 100%;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(5px);
    font-size: 1rem;
    color: #333;
    outline: none;
    transition: all 0.3s ease;
  }

  .search-input:focus {
    border-color: rgba(255, 107, 107, 0.5);
    background: rgba(255, 255, 255, 0.2);
  }

  .search-input::placeholder {
    color: rgba(0, 0, 0, 0.5);
  }

  .filter-section {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 200px;
  }

  .filter-group label {
    font-weight: bold;
    color: rgba(0, 0, 0, 0.8);
  }

  .filter-select {
    padding: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(5px);
    font-size: 1rem;
    color: #333;
    outline: none;
    transition: all 0.3s ease;
  }

  .filter-select:focus {
    border-color: rgba(255, 107, 107, 0.5);
    background: rgba(255, 255, 255, 0.2);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .post-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 15px;
    padding: 2rem;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .post-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    background: rgba(255, 255, 255, 0.15);
  }

  .post-header {
    margin-bottom: 1.5rem;
  }

  .post-title {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
    font-weight: bold;
  }

  .post-title a {
    color: inherit;
    text-decoration: none;
    background: linear-gradient(to right, #ff6b6b, #4ecdc4);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    transition: all 0.3s ease;
  }

  .post-title a:hover {
    background: linear-gradient(to right, #4ecdc4, #ff6b6b);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
    color: rgba(0, 0, 0, 0.6);
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-description {
    color: rgba(0, 0, 0, 0.8);
    line-height: 1.6;
    margin: 0;
  }

  .post-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-tag {
    background: linear-gradient(45deg, #ff6b6b, #ff8e8e);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: linear-gradient(45deg, #4ecdc4, #6ee7d7);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
  }

  .no-results {
    text-align: center;
    padding: 3rem;
    color: rgba(0, 0, 0, 0.6);
    font-size: 1.2rem;
  }

  @media (max-width: 768px) {
    .blog-list {
      padding: 1rem;
      padding-top: 5rem;
    }

    .page-title {
      font-size: 2rem;
    }

    .filter-section {
      flex-direction: column;
      gap: 1rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .post-card {
      padding: 1.5rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 检查认证状态
    if (sessionStorage.getItem('blogAuthenticated') !== 'true') {
      window.location.href = '/blog';
      return;
    }

    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const categoryFilter = document.getElementById('categoryFilter') as HTMLSelectElement;
    const tagFilter = document.getElementById('tagFilter') as HTMLSelectElement;
    const postsGrid = document.getElementById('postsGrid') as HTMLElement;
    const noResults = document.getElementById('noResults') as HTMLElement;
    const postCards = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>;

    function filterPosts() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedCategory = categoryFilter.value.toLowerCase();
      const selectedTag = tagFilter.value.toLowerCase();

      let visibleCount = 0;

      postCards.forEach(card => {
        const title = card.querySelector('.post-title a')?.textContent?.toLowerCase() || '';
        const description = card.querySelector('.post-description')?.textContent?.toLowerCase() || '';
        const author = card.querySelector('.author')?.textContent?.toLowerCase() || '';
        const categories = card.dataset.categories?.toLowerCase() || '';
        const tags = card.dataset.tags?.toLowerCase() || '';

        const matchesSearch = !searchTerm || 
          title.includes(searchTerm) || 
          description.includes(searchTerm) || 
          author.includes(searchTerm) ||
          categories.includes(searchTerm) ||
          tags.includes(searchTerm);

        const matchesCategory = !selectedCategory || categories.includes(selectedCategory);
        const matchesTag = !selectedTag || tags.includes(selectedTag);

        if (matchesSearch && matchesCategory && matchesTag) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (visibleCount === 0) {
        noResults.style.display = 'block';
        postsGrid.style.display = 'none';
      } else {
        noResults.style.display = 'none';
        postsGrid.style.display = 'grid';
      }
    }

    searchInput.addEventListener('input', filterPosts);
    categoryFilter.addEventListener('change', filterPosts);
    tagFilter.addEventListener('change', filterPosts);

    // 添加退出功能
    const blogContainer = document.querySelector('.blog-container');
    if (blogContainer) {
      const logoutButton = document.createElement('button');
      logoutButton.textContent = 'Logout';
      logoutButton.className = 'logout-button';
      logoutButton.style.cssText = `
        position: absolute;
        top: 1rem;
        right: 1rem;
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        backdrop-filter: blur(8px);
        background: rgba(255, 107, 107, 0.15);
        border: 1px solid rgba(255, 107, 107, 0.3);
        border-radius: 9999px;
        font-size: 1rem;
        color: #333;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s ease;
        z-index: 1000;
      `;
      
      logoutButton.addEventListener('click', (e) => {
        e.preventDefault();
        sessionStorage.removeItem('blogAuthenticated');
        window.location.href = '/blog';
      });

      logoutButton.addEventListener('mouseenter', () => {
        logoutButton.style.background = 'rgba(255, 107, 107, 0.25)';
        logoutButton.style.transform = 'translateY(-2px)';
        logoutButton.style.boxShadow = '0 5px 15px rgba(255, 107, 107, 0.3)';
      });

      logoutButton.addEventListener('mouseleave', () => {
        logoutButton.style.background = 'rgba(255, 107, 107, 0.15)';
        logoutButton.style.transform = 'translateY(0)';
        logoutButton.style.boxShadow = 'none';
      });

      logoutButton.addEventListener('mousedown', () => {
        logoutButton.style.transform = 'translateY(0)';
        logoutButton.style.background = 'rgba(255, 107, 107, 0.3)';
      });

      logoutButton.addEventListener('mouseup', () => {
        logoutButton.style.transform = 'translateY(-2px)';
        logoutButton.style.background = 'rgba(255, 107, 107, 0.25)';
      });

      blogContainer.appendChild(logoutButton);
    }
  });
</script>
